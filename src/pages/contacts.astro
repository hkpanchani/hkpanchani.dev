---
import Base from '../layouts/Base.astro';

const contacts = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
    label: 'Email',
    value: 'hello@hkpanchani.dev',
    href: 'mailto:hello@hkpanchani.dev',
    color: '#6366f1',
  },
];

const socials = [
  { name: 'GitHub', href: 'https://github.com/hkpanchani', icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>` },
];
---

<Base title="Contact — Hiren Panchani" description="Get in touch with Hiren Panchani — Solutions Architect, Cloud & Platform Engineering.">

  <section class="contact-hero">
    <div class="contact-bg">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
    </div>

    <div class="container">
      <!-- Terminal-style header -->
      <div class="terminal-block reveal">
        <div class="terminal-header">
          <span class="terminal-dot red"></span>
          <span class="terminal-dot yellow"></span>
          <span class="terminal-dot green"></span>
          <span class="terminal-title">hiren@hkpanchani ~ % </span>
        </div>
        <div class="terminal-body">
          <div class="terminal-line">
            <span class="term-prompt">$</span>
            <span class="term-cmd" id="terminalCmd"></span>
            <span class="term-cursor">▋</span>
          </div>
          <div class="terminal-output" id="terminalOutput"></div>
        </div>
      </div>

      <div class="contact-header reveal reveal-delay-1">
        <h1 class="section-title">Let's <span class="gradient-text">Connect</span></h1>
        <p class="section-subtitle">
          Whether you have a platform challenge, an interesting project, or just want to talk
          cloud architecture over coffee — drop me a line.
        </p>
      </div>

      <div class="contact-grid">
        <div class="contact-cards">
          {contacts.map((c, i) => (
            <a href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} rel={c.href.startsWith('http') ? 'noopener' : undefined} class={`contact-card glass-card reveal reveal-delay-${i + 1}`} style={`--card-color: ${c.color}`}>
              <div class="contact-icon" set:html={c.icon}></div>
              <div class="contact-info">
                <span class="contact-label">{c.label}</span>
                <span class="contact-value">{c.value}</span>
              </div>
              <svg class="contact-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          ))}
        </div>

        <div class="contact-side reveal reveal-delay-3">
          <div class="social-card glass-card">
            <h3>Find me online</h3>
            <div class="social-links">
              {socials.map((s) => (
                <a href={s.href} target="_blank" rel="noopener" class="social-link" aria-label={s.name}>
                  <span class="social-icon" set:html={s.icon}></span>
                  <span>{s.name}</span>
                </a>
              ))}
            </div>
          </div>

          <div class="quote-card glass-card">
            <span class="quote-icon">&gt;_</span>
            <p class="quote-text">"Infrastructure is poetry written in YAML and executed at 3 AM."</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-hero {
    position: relative;
    min-height: 100vh;
    padding-top: 8rem;
    padding-bottom: 4rem;
    overflow: hidden;
  }

  .contact-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .contact-bg .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    animation: float 20s ease-in-out infinite;
  }

  .contact-bg .orb-1 {
    width: 500px; height: 500px;
    background: rgba(99,102,241,0.1);
    top: 10%; right: -10%;
  }

  .contact-bg .orb-2 {
    width: 400px; height: 400px;
    background: rgba(6,182,212,0.07);
    bottom: 10%; left: -5%;
    animation-delay: -10s;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(30px, -40px) scale(1.05); }
    50% { transform: translate(-20px, 20px) scale(0.95); }
    75% { transform: translate(15px, 30px) scale(1.02); }
  }

  /* ── Terminal ── */
  .terminal-block {
    background: rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 3rem;
    max-width: 640px;
    font-family: var(--font-mono);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .terminal-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
  }

  .terminal-dot.red { background: #ff5f57; }
  .terminal-dot.yellow { background: #febc2e; }
  .terminal-dot.green { background: #28c840; }

  .terminal-title {
    margin-left: 0.5rem;
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .terminal-body {
    padding: 1rem 1.25rem;
  }

  .terminal-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
  }

  .term-prompt { color: var(--accent-3); font-weight: 700; }
  .term-cmd { color: var(--text-primary); }

  .term-cursor {
    color: var(--accent-1);
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .terminal-output {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.6;
    min-height: 3rem;
  }

  .contact-header {
    margin-bottom: 3rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 2rem;
    align-items: start;
  }

  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem 1.75rem;
    text-decoration: none;
    cursor: pointer;
    position: relative;
  }

  .contact-card:hover {
    border-color: color-mix(in srgb, var(--card-color) 30%, transparent);
  }

  .contact-card:hover .contact-arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  .contact-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--card-color) 10%, transparent);
    color: var(--card-color);
    flex-shrink: 0;
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    display: block;
  }

  .contact-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    display: block;
    margin-top: 0.15rem;
  }

  .contact-arrow {
    margin-left: auto;
    color: var(--text-muted);
    opacity: 0;
    transform: translate(-4px, 4px);
    transition: all var(--transition);
  }

  /* Side */
  .contact-side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .social-card {
    padding: 1.75rem;
  }

  .social-card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all var(--transition);
  }

  .social-link:hover {
    background: rgba(255,255,255,0.04);
    color: var(--text-primary);
  }

  .social-icon {
    display: flex;
    align-items: center;
    opacity: 0.7;
  }

  .social-link:hover .social-icon { opacity: 1; }

  /* Quote card replaces availability */
  .quote-card {
    display: flex;
    gap: 1rem;
    padding: 1.75rem;
    align-items: flex-start;
  }

  .quote-icon {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-2);
    flex-shrink: 0;
  }

  .quote-text {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Terminal typing animation
  const cmd = 'curl -s https://hkpanchani.dev/api/contact';
  const output = `{
  "email": "hello@hkpanchani.dev",
  "github": "github.com/hkpanchani",
  "response_time": "< 24h",
  "preferred": "email"
}`;

  const cmdEl = document.getElementById('terminalCmd');
  const outEl = document.getElementById('terminalOutput');
  let i = 0;

  function typeCmd() {
    if (i < cmd.length) {
      if (cmdEl) cmdEl.textContent += cmd[i];
      i++;
      setTimeout(typeCmd, 40 + Math.random() * 30);
    } else {
      setTimeout(() => {
        if (outEl) outEl.innerHTML = `<pre style="margin:0;color:#9595a8">${output}</pre>`;
      }, 400);
    }
  }

  const termObs = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        setTimeout(typeCmd, 600);
        termObs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  const termBlock = document.querySelector('.terminal-block');
  if (termBlock) termObs.observe(termBlock);
</script>
