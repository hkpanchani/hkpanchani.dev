  function addLine(html: string) {
    const el = document.createElement('pre');
    el.className = 'term-line';
    el.innerHTML = html;
    output.appendChild(el);
    output.scrollTop = output.scrollHeight;
  }

  function exec(cmd: string) {
    const trimmed = cmd.trim().toLowerCase();
    addLine(`<span class="t-prompt">$</span> <span class="t-cmd">${cmd}</span>`);

    if (trimmed === 'clear') {
      output.innerHTML = '';
      return;
    }

    const handler = commands[trimmed];
    if (handler) {
      const result = handler();
      addLine(result);
    } else if (trimmed === '') {
      // empty, do nothing
    } else {
      addLine(`<span class="t-error">command not found: ${trimmed}</span>. Type <span class="t-cmd">help</span> for available commands.`);
    }
    addLine('&nbsp;');
  }

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const val = input.value;
      history.unshift(val);
      histIdx = -1;
      exec(val);
      input.value = '';
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (histIdx < history.length - 1) {
        histIdx++;
        input.value = history[histIdx];
      }
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (histIdx > 0) {
        histIdx--;
        input.value = history[histIdx];
      } else {
        histIdx = -1;
        input.value = '';
      }
    }
  });

  // ═══ LIVE UPTIME TICKER ═══
  // Work periods (gaps excluded):
  // May 2015 – Jul 2016 (NetBits)
  // Oct 2019 – Oct 2021 (RK University)
  // Mar 2022 – now (Solutions Architect)
  const workPeriods: [Date, Date | null][] = [
    [new Date(2015, 4, 1), new Date(2016, 6, 1)],   // May 2015 – Jul 2016
    [new Date(2019, 9, 1), new Date(2021, 9, 1)],   // Oct 2019 – Oct 2021
    [new Date(2022, 2, 1), null],                     // Mar 2022 – present
  ];

  function getTotalWorkMs(): number {
    let total = 0;
    const now = Date.now();
    for (const [start, end] of workPeriods) {
      const s = start.getTime();
      const e = end ? end.getTime() : now;
      total += e - s;
    }
    return total;
  }

  function formatUptime(): string {
    const elapsed = getTotalWorkMs();
    const secs = Math.floor(elapsed / 1000);
    const mins = Math.floor(secs / 60);
    const hrs = Math.floor(mins / 60);
    const days = Math.floor(hrs / 24);
    const years = Math.floor(days / 365);
    const remDays = days % 365;
    const remHrs = hrs % 24;
    const remMins = mins % 60;
    const remSecs = secs % 60;
    return `up ${years}y ${remDays}d ${remHrs}h ${remMins}m ${remSecs}s`;
  }

  const uptimeEl = document.getElementById('liveUptime');
  function tickUptime() {
    if (uptimeEl) uptimeEl.textContent = formatUptime();
    requestAnimationFrame(tickUptime);
  }
  tickUptime();

  // ═══ WINDOW CONTROLS ═══
  const termEl = document.querySelector('.live-terminal') as HTMLElement;
  const reopenBtn = document.getElementById('termReopen');

  // Close — hides terminal, shows reopen button
  document.getElementById('termClose')?.addEventListener('click', () => {
    termEl?.classList.add('closed');
    reopenBtn?.classList.add('visible');
  });

  // Reopen
  reopenBtn?.addEventListener('click', () => {
    termEl?.classList.remove('closed');
    reopenBtn?.classList.remove('visible');
    input?.focus();
  });

  // Minimize — collapses output, keeps chrome bar
  document.getElementById('termMinimize')?.addEventListener('click', () => {
    termEl?.classList.toggle('minimized');
    if (!termEl?.classList.contains('minimized')) input?.focus();
  });

  // Maximize — fullscreen terminal
  document.getElementById('termMaximize')?.addEventListener('click', () => {
    termEl?.classList.toggle('maximized');
    input?.focus();
  });

  // Escape to exit maximize
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && termEl?.classList.contains('maximized')) {
      termEl.classList.remove('maximized');
    }
  });

  // New Tab — opens a new blank "tab" (clears terminal)
  document.getElementById('termNewTab')?.addEventListener('click', () => {
    output.innerHTML = '';
    const title = document.getElementById('termTitle');
    if (title) title.textContent = 'hiren@hkpanchani.dev ~ %';
    addLine('<span class="t-system">New session started. Type <span class="t-cmd">help</span> for commands.</span>');
    addLine('&nbsp;');
    input?.focus();
  });

  // ═══ TERMINAL SETTINGS ═══
  const terminal = document.querySelector('.live-terminal') as HTMLElement;
  const settingsBtn = document.getElementById('termSettingsBtn');
  const settingsPanel = document.getElementById('termSettings');

  settingsBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    settingsPanel?.classList.toggle('open');
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as Element)?.closest('.term-settings') && !(e.target as Element)?.closest('.term-settings-btn')) {
      settingsPanel?.classList.remove('open');
    }
  });

  // Theme buttons
  document.querySelectorAll('.ts-theme').forEach((btn) => {
    btn.addEventListener('click', () => {
      const theme = (btn as HTMLElement).dataset.ttheme || 'dark';
      if (theme === 'dark') { terminal?.removeAttribute('data-ttheme'); }
      else { terminal?.setAttribute('data-ttheme', theme); }
      document.querySelectorAll('.ts-theme').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      localStorage.setItem('hp-ttheme', theme);
    });
  });

  // Font buttons
  document.querySelectorAll('.ts-font').forEach((btn) => {
    btn.addEventListener('click', () => {
      const font = (btn as HTMLElement).dataset.tfont || 'mono';
      if (font === 'mono') { terminal?.removeAttribute('data-tfont'); }
      else { terminal?.setAttribute('data-tfont', font); }
      document.querySelectorAll('.ts-font').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      localStorage.setItem('hp-tfont', font);
    });
  });

  // Size buttons
  document.querySelectorAll('.ts-size').forEach((btn) => {
    btn.addEventListener('click', () => {
      const size = (btn as HTMLElement).dataset.tsize || 'md';
      if (size === 'md') { terminal?.removeAttribute('data-tsize'); }
      else { terminal?.setAttribute('data-tsize', size); }
      document.querySelectorAll('.ts-size').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      localStorage.setItem('hp-tsize', size);
    });
  });

  // Glow toggle
  document.querySelectorAll('.ts-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const glow = (btn as HTMLElement).dataset.tglow || 'on';
      terminal?.setAttribute('data-tglow', glow);
      document.querySelectorAll('.ts-toggle').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      localStorage.setItem('hp-tglow', glow);
    });
  });

  // Restore saved settings
  const savedTTheme = localStorage.getItem('hp-ttheme') || 'dark';
  const savedTFont = localStorage.getItem('hp-tfont') || 'mono';
  const savedTSize = localStorage.getItem('hp-tsize') || 'md';
  const savedTGlow = localStorage.getItem('hp-tglow') || 'on';

  if (savedTTheme !== 'dark') terminal?.setAttribute('data-ttheme', savedTTheme);
  if (savedTFont !== 'mono') terminal?.setAttribute('data-tfont', savedTFont);
  if (savedTSize !== 'md') terminal?.setAttribute('data-tsize', savedTSize);
  terminal?.setAttribute('data-tglow', savedTGlow);

  document.querySelectorAll('.ts-theme').forEach(b => b.classList.toggle('active', (b as HTMLElement).dataset.ttheme === savedTTheme));
  document.querySelectorAll('.ts-font').forEach(b => b.classList.toggle('active', (b as HTMLElement).dataset.tfont === savedTFont));
  document.querySelectorAll('.ts-size').forEach(b => b.classList.toggle('active', (b as HTMLElement).dataset.tsize === savedTSize));
  document.querySelectorAll('.ts-toggle').forEach(b => b.classList.toggle('active', (b as HTMLElement).dataset.tglow === savedTGlow));

  // Auto-focus on page load
  input?.focus();

  // Click anywhere in terminal to focus input
  document.querySelector('.live-terminal')?.addEventListener('click', () => {
    input?.focus();
  });
</script>
