---
const education = [
  {
    degree: 'B.Tech — Computer Engineering',
    year: 'Jul 2019',
    cgpa: '9.30',
    highlight: 'University Gold Medalist',
  },
  {
    degree: 'Diploma — Computer Engineering',
    year: 'Jun 2016',
    cgpa: '9.40',
    highlight: 'Gold Medal — 1st Rank University-Wide',
  },
];

const certifications = [
  {
    name: 'AWS Certified Solutions Architect — Professional',
    issuer: 'Amazon Web Services',
    date: 'Mar 2025',
    color: '#ff9900',
  },
  {
    name: 'AWS Certified Security — Specialty',
    issuer: 'Amazon Web Services',
    date: 'Feb 2026',
    color: '#ff9900',
  },
  {
    name: 'CCNP — Routing & Switching',
    issuer: 'Cisco',
    date: 'Jul 2016',
    color: '#049fd9',
  },
  {
    name: 'CCNA — Routing & Switching',
    issuer: 'Cisco',
    date: 'Jul 2016',
    color: '#049fd9',
  },
];
---

<section class="education-section" id="education">
  <div class="container">
    <div class="edu-grid">
      <!-- Education -->
      <div class="edu-col reveal-left">
        <h2 class="section-title">Education & <span class="gradient-text">Awards</span></h2>

        <div class="edu-cards">
          {education.map((e) => (
            <div class="edu-card glass-card">
              <div class="edu-badge">🏅</div>
              <div class="edu-info">
                <h3 class="edu-degree">{e.degree}</h3>
                <div class="edu-meta">
                  <span class="edu-year">{e.year}</span>
                  <span class="edu-cgpa">CGPA {e.cgpa}</span>
                </div>
                <span class="edu-highlight">{e.highlight}</span>
              </div>
            </div>
          ))}
        </div>

        <div class="gold-banner glass-card">
          <span class="gold-icon">🏆</span>
          <span class="gold-text">2× University Gold Medalist</span>
        </div>
      </div>

      <!-- Certifications -->
      <div class="cert-col reveal-right reveal-delay-2">
        <h2 class="section-title"><span class="gradient-text">Certifications</span></h2>

        <div class="cert-cards">
          {certifications.map((c) => (
            <div class="cert-card glass-card">
              <div class="cert-bar" style={`background: ${c.color}`}></div>
              <div class="cert-info">
                <h3 class="cert-name">{c.name}</h3>
                <div class="cert-meta">
                  <span class="cert-issuer">{c.issuer}</span>
                  <span class="cert-date">{c.date}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .edu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .edu-cards, .cert-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .edu-card {
    display: flex;
    gap: 1rem;
    padding: 1.5rem;
    align-items: flex-start;
  }

  .edu-badge {
    font-size: 1.8rem;
    flex-shrink: 0;
  }

  .edu-degree {
    font-size: 1rem;
    font-weight: 700;
  }

  .edu-meta {
    display: flex;
    gap: 1rem;
    margin-top: 0.25rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .edu-cgpa {
    font-family: var(--font-mono);
    color: var(--accent-3);
    font-weight: 600;
  }

  .edu-highlight {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #eab308;
    padding: 0.2rem 0.6rem;
    background: rgba(234,179,8,0.08);
    border: 1px solid rgba(234,179,8,0.2);
    border-radius: 4px;
  }

  .gold-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    margin-top: 1rem;
    background: linear-gradient(135deg, rgba(234,179,8,0.06), rgba(234,179,8,0.02));
    border-color: rgba(234,179,8,0.15);
  }

  .gold-icon { font-size: 1.5rem; }

  .gold-text {
    font-size: 1.05rem;
    font-weight: 700;
    color: #eab308;
  }

  /* Certs */
  .cert-card {
    display: flex;
    gap: 0;
    padding: 0;
    overflow: hidden;
  }

  .cert-bar {
    width: 4px;
    flex-shrink: 0;
  }

  .cert-info {
    padding: 1.25rem 1.5rem;
  }

  .cert-name {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .cert-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.35rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .cert-date {
    font-family: var(--font-mono);
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .edu-grid { grid-template-columns: 1fr; }
  }
</style>
